<odoo>
    <!-- Define the Action to trigger the PDF printing -->
    <record id="action_report_hr_leave" model="ir.actions.report">
        <field name="name">طباعة طلب الإجازة</field>
        <field name="model">hr.leave</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_leave_report_print.report_leave_request_template</field>
        <field name="report_file">hr_leave_report_print.report_leave_request_template</field>
        <field name="print_report_name">'طلب إجازة - %s' % (object.employee_id.name)</field>
        <field name="binding_model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="binding_type">report</field>
    </record>

    <!-- HTML/QWeb Template for the PDF layout (Arabic/English Friendly) -->
    <template id="report_leave_request_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="direction: rtl; text-align: right; font-family: 'Cairo', 'Helvetica', sans-serif;">
                        <div class="text-center" style="border-bottom: 2px solid #714B67; padding-bottom: 10px; margin-bottom: 30px;">
                            <h2>تفاصيل طلب الإجازة / Leave Request Details</h2>
                        </div>

                        <table class="table table-bordered" style="width: 100%; border: 1px solid #cccccc;">
                            <tbody>
                                <tr>
                                    <td style="width: 25%; background-color: #f2f2f2; font-weight: bold;">الموظف:</td>
                                    <td style="width: 25%;"><span t-field="o.employee_id.name"/></td>
                                    <td style="width: 25%; background-color: #f2f2f2; font-weight: bold;">نوع الإجازة:</td>
                                    <td style="width: 25%;"><span t-field="o.holiday_status_id.name"/></td>
                                </tr>
                                <tr>
                                    <td style="background-color: #f2f2f2; font-weight: bold;">تاريخ البدء:</td>
                                    <td><span t-field="o.date_from" t-options='{"widget": "date"}'/></td>
                                    <td style="background-color: #f2f2f2; font-weight: bold;">تاريخ الانتهاء:</td>
                                    <td><span t-field="o.date_to" t-options='{"widget": "date"}'/></td>
                                </tr>
                                <tr>
                                    <td style="background-color: #f2f2f2; font-weight: bold;">المدة:</td>
                                    <td><span t-field="o.number_of_days"/> أيام</td>
                                    <td style="background-color: #f2f2f2; font-weight: bold;">الحالة:</td>
                                    <td><span t-field="o.state"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div style="margin-top: 30px;">
                            <h5>السبب / الوصف:</h5>
                            <div style="border: 1px solid #cccccc; padding: 15px; min-height: 80px; background-color: #fafafa;">
                                <span t-field="o.name"/>
                            </div>
                        </div>

                        <!-- Signatures Section -->
                        <div style="margin-top: 60px; width: 100%;">
                            <table style="width: 100%; border: none;">
                                border: none;
                                <tr>
                                    <td style="width: 50%; text-align: center; border: none;">
                                        <p>توقيع الموظف</p>
                                        <p>____________________</p>
                                    </td>
                                    <td style="width: 50%; text-align: center; border: none;">
                                        <p>اعتماد الموارد البشرية / المدير</p>
                                        <p>____________________</p>
                                    </td>
                                </tr>
                            </table>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
