<odoo>
    <!--form-->
    <record id="form_payroll_monthly_statement_dev_payroll_monthly_statement" model="ir.ui.view">
        <field name="name">form_payroll_monthly_statement_dev_payroll_monthly_statement_name</field>
        <field name="model">payroll.monthly.statement</field>
        <field name="arch" type="xml">
            <form string="Payroll Monthly Statement">
                <group>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                    <group>
                        <field name="filter_by"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <separator string="Employee"  invisible="filter_by != 'employee'"/>
                <!-- attrs="{'invisible': [('filter_by', '!=', 'employee')]}" -->
                <field name="employee_ids"  invisible="filter_by != 'employee'"/>
                <!-- attrs="{'invisible': [('filter_by', '!=', 'employee')]}" -->
                <separator string="Department"  invisible="filter_by != 'department'"/>
                <!-- attrs="{'invisible': [('filter_by', '!=', 'department')]}" -->
                <field name="department_ids"  invisible="filter_by != 'department'"/>
                <!-- attrs="{'invisible': [('filter_by', '!=', 'department')]}" -->
                <footer>
                    <button string="Print PDF" name="print_monthly_payroll_statement" type="object" class="oe_highlight" icon="fa-print"/>
                    &#160;or&#160;
                    <button string="Print Excel" name="export_payroll_monthly_statement" type="object" class="oe_highlight" icon="fa-file-excel-o"/>
                    &#160;or&#160;
                    <button string="Close Window" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <!--action-->
    <record id="action_payroll_monthly_statement_dev_payroll_monthly_statement" model="ir.actions.act_window">
        <field name="name">Payroll Monthly Statement</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">payroll.monthly.statement</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="form_payroll_monthly_statement_dev_payroll_monthly_statement"/>
        <field name="target">new</field>
    </record>
    <!--Menus-->
    <menuitem name="Payroll Monthly Statement"
              id="menu_payroll_monthly_statement_dev_payroll_monthly_statement"
              parent="hr_payroll.menu_hr_payroll_report"
              action="action_payroll_monthly_statement_dev_payroll_monthly_statement"
              sequence="99"/>
</odoo>