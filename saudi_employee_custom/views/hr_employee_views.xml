<odoo>
    <record id="view_employee_form_inherit_saudi" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.saudi</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='country_id']" position="after">
                <field name="is_saudi"/>
            </xpath>
        </field>
    </record>
</odoo>
