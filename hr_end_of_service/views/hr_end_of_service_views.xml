<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_end_of_service_form" model="ir.ui.view">
        <field name="name">hr.end.of.service.form</field>
        <field name="model">hr.end.of.service</field>
        <field name="arch" type="xml">
            <form string="End of Service Request">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" states="draft"/>
                    <button name="action_done" type="object" string="Done" states="confirmed"/>
                    <button name="action_cancel" type="object" string="Cancel" states="draft,confirmed"/>
                    <button name="action_reset_draft" type="object" string="Reset" states="cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="contract_id" readonly="1"/>
                            <field name="salary"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="request_date"/>
                            <field name="termination_date"/>
                            <field name="relation_state"/>
                            <field name="termination_reason"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="service_years" readonly="1"/>
                            <field name="service_months" readonly="1"/>
                            <field name="service_days" readonly="1"/>
                        </group>
                        <group>
                            <field name="gross_entitlement" readonly="1"/>
                            <field name="deductions"/>
                            <field name="net_entitlement" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_end_of_service_tree" model="ir.ui.view">
        <field name="name">hr.end.of.service.tree</field>
        <field name="model">hr.end.of.service</field>
        <field name="arch" type="xml">
            <tree string="End of Service Requests">
                <field name="employee_id"/>
                <field name="contract_id"/>
                <field name="termination_date"/>
                <field name="termination_reason"/>
                <field name="gross_entitlement"/>
                <field name="net_entitlement"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_hr_end_of_service" model="ir.actions.act_window">
        <field name="name">End of Service Requests</field>
        <field name="res_model">hr.end.of.service</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Create a new end of service request for an employee.
            </p>
        </field>
    </record>

    <menuitem id="menu_hr_end_of_service"
              name="End of Service"
              parent="hr.menu_hr_root"
              action="action_hr_end_of_service"/>
</odoo>
